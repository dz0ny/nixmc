---
import { Font } from "astro:assets";
import "../index.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Schema } from "astro-seo-schema";
import type { Thing, WithContext } from "schema-dts";

interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
	socialImageUrl?: string;
	schema?: WithContext<Thing> | WithContext<Thing>[];
}

const SITE_NAME = "NixMC";
const SITE_DESCRIPTION =
	"Manage your Mac by describing the change you want. A native menu-bar app that puts a coding agent in front of your nix-darwin configuration, with a diff you review before anything applies.";

const { url } = Astro;
const {
	title: pageTitle,
	description = SITE_DESCRIPTION,
	noindex = false,
	socialImageUrl,
	schema,
} = Astro.props;

const title = pageTitle ? `${pageTitle} | ${SITE_NAME}` : `${SITE_NAME} · describe the change, review the diff`;

// Default social share image (absolute URL, base-aware). Pages may override via socialImageUrl.
const socialImage = socialImageUrl ?? new URL(`${import.meta.env.BASE_URL}og.png`, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const dark = stored ? stored === "dark" : true;
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
    <link rel="canonical" href={url.href} />
    <Font cssVariable="--font-grotesk" preload />
    <Font cssVariable="--font-mono-code" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1117" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {schema && (Array.isArray(schema)
      ? schema.map((s) => <Schema item={s} />)
      : <Schema item={schema} />
    )}
  </head>

  <body class="min-h-screen bg-background text-foreground flex flex-col font-sans antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

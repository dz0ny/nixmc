---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import WorksWith from "@/components/WorksWith.astro";
import Features from "@/components/Features.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import Recipes from "@/components/Recipes.astro";
import Requirements from "@/components/Requirements.astro";
import CTA from "@/components/CTA.astro";
import { SITE } from "@/config";
import type { SoftwareApplication, WithContext } from "schema-dts";

const schema: WithContext<SoftwareApplication> = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "NixMC",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS 14+",
  description:
    "A native macOS menu-bar app that puts a coding agent in front of a nix-darwin configuration. Describe a change in plain English; NixMC edits the flake, validates the build, shows a diff, and commits to git for rollback.",
  url: `${Astro.site?.origin ?? ""}${import.meta.env.BASE_URL}`,
  downloadUrl: SITE.releases,
  license: `${SITE.repo}/blob/main/LICENSE`,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<Layout schema={schema}>
  <Hero />
  <WorksWith />
  <Features />
  <HowItWorks />
  <Recipes />
  <Requirements />
  <CTA />
</Layout>

---
import { ListChecks, Bot, TerminalSquare, GitCompareArrows, Check } from "lucide-react";

const steps = [
  {
    icon: ListChecks,
    title: "Describe or choose",
    body: "Type the result you want in plain English, or pick a proven recipe from the catalog.",
  },
  {
    icon: Bot,
    title: "The agent edits",
    body: "Claude Code or Codex edits the configuration repository non-interactively, with permission to touch only the flake.",
  },
  {
    icon: TerminalSquare,
    title: "Format & build",
    body: "NixMC formats the flake and validates it with darwin-rebuild build before anything is shown as final.",
  },
  {
    icon: GitCompareArrows,
    title: "Review the diff",
    body: "Inspect the complete, generated diff and the build output. Nothing is applied until you say so.",
  },
  {
    icon: Check,
    title: "Apply & commit",
    body: "Activate with administrator approval. The change is committed to git so you can inspect or roll it back later.",
  },
];
---

<section id="how" class="scroll-mt-20 border-b border-border bg-muted/40">
  <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
        From a sentence to a reviewed change
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
        The agent runs non-interactively with permission to edit the configuration.
        You always review the proposed diff before applying it.
      </p>
    </div>

    <ol class="mt-16 grid gap-y-10 sm:grid-cols-2 lg:grid-cols-5 lg:gap-x-4">
      {steps.map((s, i) => (
        <li class="relative flex flex-col">
          <div class="flex items-center gap-4 lg:block">
            <div class="relative z-10 flex h-12 w-12 flex-none items-center justify-center rounded-xl border border-brand/20 bg-brand-soft text-brand shadow-soft">
              <s.icon className="h-5 w-5" />
            </div>
            {i < steps.length - 1 && (
              <span
                class="hidden h-px flex-1 bg-gradient-to-r from-brand/40 to-border lg:absolute lg:left-12 lg:top-6 lg:block lg:w-[calc(100%-3rem)]"
                aria-hidden="true"
              ></span>
            )}
            <h3 class="text-base font-semibold lg:mt-5">{s.title}</h3>
          </div>
          <p class="mt-2 pl-16 text-sm leading-relaxed text-muted-foreground lg:pl-0 lg:pr-4">
            {s.body}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>

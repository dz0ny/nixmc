---
import { Picture } from "astro:assets";
import icon from "@/assets/nixmc-icon.png";
import { SITE, BASE } from "@/config";

const nav = [
  { label: "Features", href: "#features" },
  { label: "How it works", href: "#how" },
  { label: "Recipes", href: "#recipes" },
  { label: "Requirements", href: "#requirements" },
];
---

<header class="sticky top-0 z-50 border-b border-border/70 bg-background/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href={BASE} class="flex items-center gap-2.5 font-semibold tracking-tight">
      <Picture
        src={icon}
        alt="NixMC icon"
        formats={["webp"]}
        fallbackFormat="webp"
        widths={[36, 72]}
        width={36}
        height={36}
        loading="eager"
        class="h-9 w-9 rounded-[9px] shadow-soft"
      />
      <span class="text-lg">NixMC</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        >{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={SITE.repo}
        target="_blank"
        rel="noreferrer"
        class="hidden h-9 items-center rounded-lg px-3 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground sm:inline-flex"
      >GitHub</a>
      <a
        href={SITE.latestDmg}
        target="_blank"
        rel="noreferrer"
        class="inline-flex h-9 items-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground shadow-soft transition-transform hover:-translate-y-px"
      >Download</a>
    </div>
  </div>
</header>

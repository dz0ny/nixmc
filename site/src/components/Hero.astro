---
import { Picture } from "astro:assets";
import { SITE } from "@/config";
import shot from "@/assets/screenshot-recipes.png";
import { Apple, ArrowRight, ArrowUpRight } from "lucide-react";
---

<section class="relative overflow-hidden bg-gradient-hero">
  <div
    class="pointer-events-none absolute inset-0 bg-grid [background-size:44px_44px] [mask-image:radial-gradient(90%_70%_at_75%_0%,black,transparent)]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 pb-20 pt-16 sm:px-6 sm:pt-24 lg:pb-28">
    <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-8">
      <!-- Copy -->
      <div class="lg:col-span-6">
        <a
          href="#recipes"
          class="animate-fade inline-flex items-center gap-2 rounded-full border border-border bg-card/60 py-1 pl-1 pr-3 text-xs font-medium text-muted-foreground shadow-soft backdrop-blur"
        >
          <span class="rounded-full bg-brand px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-brand-foreground">New</span>
          Team-shared recipe catalogs
          <ArrowRight className="h-3.5 w-3.5" />
        </a>

        <h1
          class="animate-rise mt-6 text-balance text-4xl font-semibold leading-[1.04] tracking-tight sm:text-5xl lg:text-[3.4rem]"
        >
          Manage your Mac by
          <span class="text-brand">describing the change</span>.
        </h1>

        <p
          class="animate-rise mt-6 max-w-xl text-pretty text-lg leading-relaxed text-muted-foreground [animation-delay:120ms]"
        >
          A native menu-bar app that puts a coding agent in front of nix-darwin.
          Describe a change in plain English; NixMC edits the flake, validates the
          build, and shows the diff before it applies.
        </p>

        <div
          class="animate-rise mt-8 flex flex-col gap-3 sm:flex-row [animation-delay:220ms]"
        >
          <a
            href={SITE.latestDmg}
            target="_blank"
            rel="noreferrer"
            class="inline-flex h-12 items-center justify-center gap-2 rounded-xl bg-primary px-6 text-sm font-medium text-primary-foreground shadow-medium transition-transform hover:-translate-y-0.5"
          >
            <Apple className="h-4 w-4" />
            Download for macOS
          </a>
          <a
            href={SITE.repo}
            target="_blank"
            rel="noreferrer"
            class="inline-flex h-12 items-center justify-center gap-1.5 rounded-xl border border-border bg-card/60 px-6 text-sm font-medium backdrop-blur transition-colors hover:bg-secondary"
          >
            View source
            <ArrowUpRight className="h-4 w-4" />
          </a>
        </div>
      </div>

      <!-- App window: real screenshot framed with the app's own prompt bar -->
      <div class="animate-rise lg:col-span-6 [animation-delay:320ms]">
        <div class="lg:animate-float">
          <div class="overflow-hidden rounded-2xl bg-card shadow-glow">
            <!-- title bar -->
            <div class="flex items-center gap-2 border-b border-border/70 bg-secondary/50 px-4 py-3">
              <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
              <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
              <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
              <span class="ml-2 font-mono text-xs text-muted-foreground">NixMC</span>
            </div>

            <Picture
              src={shot}
              alt="NixMC home screen showing popular configuration recipes"
              formats={["webp"]}
              fallbackFormat="webp"
              widths={[700, 1100, 1400]}
              sizes="(min-width: 1024px) 560px, 100vw"
              loading="eager"
              class="block w-full"
            />

            <!-- prompt bar (the app's real primitive) -->
            <div class="flex items-center gap-2 border-t border-border/70 bg-secondary/40 px-4 py-3 font-mono text-sm">
              <span class="text-brand">›</span>
              <span class="text-foreground">enable Touch ID for sudo and install ripgrep</span>
              <span class="animate-caret ml-0.5 inline-block h-4 w-[2px] bg-brand align-middle"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
